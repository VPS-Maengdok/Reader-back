{
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleFileExtensions": ["ts", "js"],
    "testRegex": ".*\\.(e2e-spec|spec|test)\\.ts$",
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "moduleNameMapper": {
        "^src/(.*)$": "<rootDir>/src/$1"
    },
    "collectCoverageFrom": ["src/**/*.{ts,js}"],
    "coverageDirectory": "./coverage",
    "coveragePathIgnorePatterns": ["/node_modules/", "/dist/", "src/main.ts", "src/app.*.ts"]
}